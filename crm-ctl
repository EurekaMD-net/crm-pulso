#!/bin/bash
# crm-ctl — Management console for Agentic CRM
set -euo pipefail

PROJECT_DIR="/root/claude/crm-azteca"
SERVICE_NAME="agentic-crm"
SERVICE_FILE="/etc/systemd/system/${SERVICE_NAME}.service"
LOG_LINES=50

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

usage() {
  echo -e "${CYAN}crm-ctl${NC} — Agentic CRM Management Console"
  echo ""
  echo -e "  ${GREEN}start${NC}          Start CRM service"
  echo -e "  ${GREEN}stop${NC}           Stop CRM service"
  echo -e "  ${GREEN}restart${NC}        Restart CRM service"
  echo -e "  ${GREEN}status${NC}         Show service status"
  echo -e "  ${GREEN}logs${NC} [N]       Show last N log lines (default ${LOG_LINES})"
  echo -e "  ${GREEN}follow${NC}         Follow logs in real-time"
  echo -e "  ${GREEN}rebuild${NC}        Rebuild Docker container image"
  echo -e "  ${GREEN}rebuild-restart${NC} Rebuild container + restart service"
  echo -e "  ${GREEN}clear-sessions${NC} Clear stale agent sessions"
  echo -e "  ${GREEN}reauth${NC}         Re-authenticate WhatsApp (pairing code)"
  echo -e "  ${GREEN}db${NC} [query]     Run a SQLite query against CRM database"
  echo -e "  ${GREEN}personas${NC}       List all personas and their group mappings"
  echo -e "  ${GREEN}groups${NC}         List registered WhatsApp groups"
  echo -e "  ${GREEN}set-persona${NC} ID Set persona for 'main' group folder"
  echo -e "  ${GREEN}install${NC}        Install systemd service (first time)"
  echo ""
}

cmd_install() {
  echo -e "${YELLOW}Installing systemd service...${NC}"
  cp "${PROJECT_DIR}/systemd/agentic-crm.service" "$SERVICE_FILE"
  systemctl daemon-reload
  systemctl enable "$SERVICE_NAME"
  echo -e "${GREEN}Service installed and enabled.${NC} Run: crm-ctl start"
}

cmd_start() {
  # Kill any manual processes first
  pkill -9 -f "tsx engine/src/index" 2>/dev/null || true
  sleep 1
  systemctl start "$SERVICE_NAME"
  sleep 2
  systemctl --no-pager status "$SERVICE_NAME" | head -15
}

cmd_stop() {
  systemctl stop "$SERVICE_NAME"
  docker kill $(docker ps -q --filter "name=nanoclaw-") 2>/dev/null || true
  echo -e "${GREEN}Stopped.${NC}"
}

cmd_restart() {
  docker kill $(docker ps -q --filter "name=nanoclaw-") 2>/dev/null || true
  systemctl restart "$SERVICE_NAME"
  sleep 3
  systemctl --no-pager status "$SERVICE_NAME" | head -15
}

cmd_status() {
  echo -e "${CYAN}=== Service ===${NC}"
  systemctl --no-pager status "$SERVICE_NAME" 2>/dev/null | head -15 || echo -e "${RED}Not running${NC}"
  echo ""
  echo -e "${CYAN}=== Containers ===${NC}"
  docker ps --filter "name=nanoclaw-" --format "table {{.Names}}\t{{.Status}}\t{{.RunningFor}}" 2>/dev/null || echo "No containers"
  echo ""
  echo -e "${CYAN}=== WhatsApp ===${NC}"
  journalctl -u "$SERVICE_NAME" --no-pager -n 100 2>/dev/null | grep -m1 "Connected to WhatsApp\|authentication required\|NanoClaw running" | tail -1 || echo "Unknown"
  echo ""
  echo -e "${CYAN}=== Persona (main) ===${NC}"
  sqlite3 "${PROJECT_DIR}/data/store/crm.db" "SELECT id, nombre, rol FROM persona WHERE whatsapp_group_folder = 'main';" 2>/dev/null || echo "None mapped"
}

cmd_logs() {
  local n="${1:-$LOG_LINES}"
  journalctl -u "$SERVICE_NAME" --no-pager -n "$n"
}

cmd_follow() {
  journalctl -u "$SERVICE_NAME" -f
}

cmd_rebuild() {
  echo -e "${YELLOW}Rebuilding container image...${NC}"
  cd "$PROJECT_DIR"
  docker build --no-cache -t agentic-crm-agent:latest -f crm/container/Dockerfile crm/
  echo -e "${GREEN}Container rebuilt.${NC}"
}

cmd_rebuild_restart() {
  cmd_rebuild
  echo -e "${YELLOW}Restarting service...${NC}"
  cmd_restart
}

cmd_clear_sessions() {
  rm -rf "${PROJECT_DIR}"/groups/*/. crm-sessions/*.json 2>/dev/null
  rm -rf "${PROJECT_DIR}"/groups/*/.crm-sessions/*.json 2>/dev/null
  echo -e "${GREEN}Sessions cleared.${NC} Restart or kill container for effect."
}

cmd_reauth() {
  echo -e "${YELLOW}Stopping service...${NC}"
  cmd_stop 2>/dev/null || true
  rm -rf "${PROJECT_DIR}/store/auth/"
  echo -e "${YELLOW}Starting WhatsApp authentication...${NC}"
  echo "Enter your phone number (with country code, no + or spaces):"
  read -r phone
  cd "$PROJECT_DIR"
  npx tsx engine/src/whatsapp-auth.ts --pairing-code --phone "$phone"
  echo ""
  echo -e "${GREEN}Authentication complete.${NC} Run: crm-ctl start"
}

cmd_db() {
  if [ $# -eq 0 ]; then
    sqlite3 "${PROJECT_DIR}/data/store/crm.db"
  else
    sqlite3 "${PROJECT_DIR}/data/store/crm.db" "$*"
  fi
}

cmd_personas() {
  sqlite3 -header -column "${PROJECT_DIR}/data/store/crm.db" \
    "SELECT id, nombre, rol, reporta_a, whatsapp_group_folder FROM persona ORDER BY rol, nombre;"
}

cmd_groups() {
  sqlite3 -header -column "${PROJECT_DIR}/store/messages.db" \
    "SELECT jid, name, folder, trigger_word FROM registered_groups;"
}

cmd_set_persona() {
  local pid="${1:?Usage: crm-ctl set-persona <persona_id>}"
  sqlite3 "${PROJECT_DIR}/data/store/crm.db" "UPDATE persona SET whatsapp_group_folder = NULL WHERE whatsapp_group_folder = 'main';"
  sqlite3 "${PROJECT_DIR}/data/store/crm.db" "UPDATE persona SET whatsapp_group_folder = 'main' WHERE id = '${pid}';"
  local result
  result=$(sqlite3 "${PROJECT_DIR}/data/store/crm.db" "SELECT nombre, rol FROM persona WHERE id = '${pid}';")
  echo -e "${GREEN}Main group now mapped to: ${result}${NC}"
  # Clear sessions and kill container so next message gets fresh persona
  rm -rf "${PROJECT_DIR}"/groups/main/.crm-sessions/*.json 2>/dev/null
  docker kill $(docker ps -q --filter "name=nanoclaw-main") 2>/dev/null || true
  echo -e "${YELLOW}Sessions cleared and container killed. New persona takes effect on next message.${NC}"
}

# --- Main ---
if [ $# -eq 0 ]; then
  usage
  exit 0
fi

case "$1" in
  install)        cmd_install ;;
  start)          cmd_start ;;
  stop)           cmd_stop ;;
  restart)        cmd_restart ;;
  status)         cmd_status ;;
  logs)           shift; cmd_logs "$@" ;;
  follow)         cmd_follow ;;
  rebuild)        cmd_rebuild ;;
  rebuild-restart) cmd_rebuild_restart ;;
  clear-sessions) cmd_clear_sessions ;;
  reauth)         cmd_reauth ;;
  db)             shift; cmd_db "$@" ;;
  personas)       cmd_personas ;;
  groups)         cmd_groups ;;
  set-persona)    shift; cmd_set_persona "$@" ;;
  *)              echo -e "${RED}Unknown command: $1${NC}"; usage; exit 1 ;;
esac
